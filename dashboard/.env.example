# =============================================================================
# Google OAuth (NextAuth Google provider)
# Set these from the OAuth client created in GCP Console (see Pre-Build subtask 10)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# NextAuth
# NEXTAUTH_URL: http://localhost:3000 in dev, https://dashboard.oneeighty.cz in prod
# NEXTAUTH_SECRET: random 32+ char string. Generate: `openssl rand -base64 32`
# =============================================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# =============================================================================
# Auth restriction
# Only emails ending in this domain can sign in. Multi-domain: comma-separate.
# =============================================================================
ALLOWED_EMAIL_DOMAIN=oneeighty.cz

# =============================================================================
# BigQuery (sa-frontend-reader service account)
# GCP_SERVICE_ACCOUNT_KEY_BASE64:
#   1. Download sa-frontend-reader JSON key from GCP
#   2. base64 the file: `base64 -i sa-frontend-reader-key.json | pbcopy`
#   3. Paste here. Vercel: paste into env var with same name.
#   4. DELETE THE LOCAL JSON FILE after.
# =============================================================================
GCP_PROJECT_ID=oneeighty-warehouse
GCP_SERVICE_ACCOUNT_KEY_BASE64=
